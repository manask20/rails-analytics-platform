FROM ruby:3.3.5

# System deps (pg gem needs libpq-dev)
RUN apt-get update -qq && apt-get install -y \
  build-essential \
  libpq-dev \
  nodejs \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /rails

# Dev environment
ENV RAILS_ENV=development

# Install gems first (better layer caching)
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy app code
COPY . .

EXPOSE 3000
CMD ["bash", "-lc", "bundle exec rails s -b 0.0.0.0 -p 3000"]
